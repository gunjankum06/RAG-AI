# ── Ollama ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_MAX_RETRIES=3

# ── Vector Store ──────────────────────────────────────────────────────
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./storage/chroma
FAISS_INDEX_DIR=./storage/faiss

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────
TOP_K=5
RERANK_ENABLED=true
RERANK_TOP_N=3

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_BATCH_SIZE=64

# ── API ───────────────────────────────────────────────────────────────
API_KEY=change-me-to-a-secure-random-string
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=["*"]

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Guardrails ────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
GUARDRAILS_BLOCK_ON_FAILURE=true
GUARDRAILS_CHECK_INJECTION=true
GUARDRAILS_CHECK_TOPIC=true
GUARDRAILS_CHECK_GROUNDING=true
GUARDRAILS_CHECK_PII=true
GUARDRAILS_CHECK_QUALITY=true
GUARDRAILS_PII_REDACT=false
GUARDRAILS_GROUNDING_THRESHOLD=0.3

# ── OWASP Agent Threat Protection ─────────────────────────────────────
OWASP_CHECK_EXFILTRATION=true
OWASP_CHECK_EXCESSIVE_AGENCY=true
OWASP_CHECK_INDIRECT_INJECTION=true
OWASP_CHECK_SYSTEM_PROMPT_LEAK=true

# ── DLP (Data Loss Prevention) ────────────────────────────────────────
DLP_ENABLED=true
DLP_SCAN_INGESTION=true
DLP_BLOCK_SEVERITY=critical
DLP_REDACT_SEVERITY=high

# ── Environment ───────────────────────────────────────────────────────
ENVIRONMENT=development
